 #include<unordered_set>
#include <iostream>
using namespace std;
int main()
{
  string s = "abccba";
  int n = s.size();
 unordered_set<char>s1  ;
 int left =0;
 int maxlen = 0;
 for(int right=0;right<n;right++){
  while(s1.find(s[right])!=s1.end()){
    s1.erase(s[left]);
    left++;
  }
  s1.insert(s[right]);
  maxlen = max(maxlen,right-left+1);
 }

 cout<<maxlen<<endl;
 for(char val : s1){
  cout<<val;
 }
}
