#include <iostream>
using namespace std;
int main()
{
    string str = "my name is anish";
    string ans = "";
    int n = str.length();
    reverse(str.begin(), str.end());
    for (int i = 0; i < n; i++)
    {
        string word = "";
        while (i < n && str[i] != ' ')
        {
            word += str[i];
            i++;
        }
        reverse(word.begin(), word.end());
        if (word.length() > 0)
        {
            ans += " " + word;
        }
    }
    cout << ans.substr(1);
}
