    string n = "jak";

    int freq[26] = {0};
    for (int i = 0; i < n.length(); i++)
    {
        int idx =n[i] - 'a';
        freq[idx]++;
    }
    int windsize = n.length();
    for (int i = 0; i <= str.length()-windsize; i++)
    {
        int winidx = 0, idx = 1;
        int windfreq[26] = {0};
       for (int j=0;j < windsize; j++)
        {
