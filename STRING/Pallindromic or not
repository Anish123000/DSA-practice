#include <iostream>
#include <algorithm>
using namespace std;
bool isAlphanum(char ch)
{
    if ((ch >= '0' && ch <= '9') || (tolower(ch) >= 'a' && tolower(ch) <= 'z'))
    {
        return true;
    }
    return false;
}

int main()
{
    string str = "madAm";

    int st = 0;
    int end = str.length() - 1;
    while (st <= end)
    {
        if (!isAlphanum(str[st]))
        {
            st++;
            continue;
        }
        if (!isAlphanum(str[end]))
        {
            end--;
            continue;
        }
        if (tolower(str[st]) != tolower(str[end]))
        {
            cout<<"non pallindromic";
            return 0;
        }
        st++;
        end--;
    }

    cout << "pallindromic";
}
