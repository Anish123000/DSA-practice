#include <iostream>
#include <vector>
using namespace std;
int main()
{

    int freq = 0, ans = 0;
    vector<int> nums = {1, 2, 2, 2, 3};
    for (int i = 0; i < nums.size(); i++)
    {
        if (freq = 0)
        {
            ans = nums[i];
        }
        if (ans == nums[i])
        {
            freq++;
        }
        else
        {
            freq--;
        }
    }
    cout << ans;
}
