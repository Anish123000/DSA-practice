#include <iostream>
using namespace std;
int linearsearch(int arr[], int sz, int target)
{
    for (int i = 0; i < sz; i++)
    {
        if (arr[i] == target)
        {
            return i;
        }
    }
    return -1;
}

int main()
{
    int arr[] = {2, 8, 7, 9, 5, 1};
    int sz = 6;
    int target = 9;
    cout << linearsearch(arr, sz, target) << endl;
}
