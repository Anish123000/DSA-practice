//time complexity O(log10 n)
#include <iostream>
#include<cmath>
using namespace std;
void printdigits(int n)
{
    while (n != 0)
    {
        int digit = n % 10;
        cout << digit << " ";
        n = n / 10;
    }
}

int main()
{
    int n = 2565;
    printdigits(n);
    //standard version to print count of a number
    cout<<(int)(log10(n)+1);
    return 0;
}
