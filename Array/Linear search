#include <iostream>
#include <vector>
using namespace std;

int main()
{
    vector<int> num = {2, 3, 4, 6, 7, 8, 9};
    int target = 6;
    for (int i = 0; i < num.size(); i++)
    {
        if (num[i] == target)
        {
            cout << i << endl;
            break;
        }
    }

    return 0;
}
