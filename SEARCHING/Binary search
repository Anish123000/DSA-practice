#include <iostream>
#include <vector>
using namespace std;
int binarysearch(vector<int> arr, int tar)
{
    int st = 0, end = arr.size() - 1;
    while (st <= end)
    {
        int mid = (st + end) / 2;
        if (tar > arr[mid])
        {
            st = mid + 1;
        }
        else if (tar < arr[mid])
        {
            end = mid - 1;
        }
        else
        {
            return mid;
        }
    }
    return -1;
}

int main()
{
    vector<int> arr1 = {-1, 0, 2, 3, 7, 8, 9};
    int target1 = 9;
    vector<int> arr2 = {1, 3, 5, 4, 6, 9};
    int target2 = 5;
    cout << binarysearch(arr1, target1) << "  Is the target index " << endl;
    cout << binarysearch(arr2, target2) << "  Is the target index " << endl;
}
