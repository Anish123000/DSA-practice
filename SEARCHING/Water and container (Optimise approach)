#include <iostream>
#include <vector>
using namespace std;
int main()
{
    vector<int> height = {1, 8, 6, 2, 5, 4, 8, 3, 7};
    int n = height.size();
    int maxwater = 0;
    int lp = 0, rp = n - 1;

    while (lp < rp)
    {
        int he = min(height[lp], height[rp]);
        int width = rp - lp;
        int currwater = he * width;
        maxwater = max(maxwater, currwater);
        if (height[lp] < height[rp])
        {
            lp++;
        }
        else
        {
            rp--;
        }
    }

    cout << maxwater << endl;
}
