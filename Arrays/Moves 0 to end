#include <iostream>
using namespace std;
int main()
{

    int arr[] = {3, 0, 7,  6, 0};
    int j = 0;
    for (int i = 0; i < 5; i++)
    {
        if (arr[i] != 0)
        {
            arr[j] = arr[i];
            j++;
            cout << arr[i]<<" ";
        }
    }
    for (int k = j; k < 5; k++)
    {
        cout << "0"<<" ";
    }

}
 
