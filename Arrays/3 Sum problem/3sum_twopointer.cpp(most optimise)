
#include <set>
#include <algorithm>
#include <iostream>
#include <vector>
using namespace std;
int main()
{
    vector<int> vec = {-1, 0, 1, 2, -1, -4};
    vector<vector<int>> ans;
    int n = vec.size();
    sort(vec.begin(), vec.end());
    for (int i = 0; i < n; i++)
    {
        if (i > 0 && vec[i] == vec[i - 1])
        {
            continue;
        }
        int j = i + 1, k = n - 1;
        while (j < k)
        {
            int sum = vec[i] + vec[j] + vec[k];
            if (sum < 0)
            {
                j++;
            }
            else if (sum > 0)
            {
                k--;
            }
            else
            {
                ans.push_back({vec[i], vec[j], vec[k]});
                j++, k--;
                while (j < k && vec[j] == vec[j - 1])

                    j++;

                while (j < k && vec[k] == vec[k - 1])
                    k--;
            }
        }
    }

    for (auto trip : ans)
    {
        cout << "[ ";
        for (auto x : trip)
            cout << x << " ";
        cout << "]\n";
    }
}
