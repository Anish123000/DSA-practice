
#include <iostream>
#include <algorithm>
using namespace std;
int diagonalsum(int mat[][3], int n)
{
    int sum = 0;
    for (int i = 0; i < n; i++)
    {

        sum += mat[i][i];

        if (i != n - i - 1)
        {
            sum += mat[i][n - i - 1];
        }
    }
    return sum;
}

int main()
{
    int matrix[4][3] = {{1, 2, 3}, {4, 5, 6}, {7, 8, 9}};
    int n = 3;

    cout << diagonalsum(matrix, n) << endl;
}
