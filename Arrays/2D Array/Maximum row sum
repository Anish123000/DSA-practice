#include <iostream>
#include<algorithm>
using namespace std;
int getmaxsum(int mat[][3],int rows,int columns){
    int maxsum = INT_MIN;
        for (int i = 0; i < rows; i++){
        int rowsum = 0;
   
        for (int j = 0; j < columns; j++)
        {
           rowsum += mat[i][j];
        }
        maxsum = max(maxsum,rowsum);
    }
    return maxsum;
}

int main()
{
    int matrix[4][3] ={ {1,2,3},{4,5,6},{7,8,9} }  ;
    int row = 3;
    int column = 3;
 cout<<getmaxsum(matrix,row,column)<<endl;
 
}
