
#include <iostream>
using namespace std;
int main()
{
  int arr[] = {1, 2, 3, 4, 5, 6, 7};
  int k = 3;
  int n = 7;
  int left = 0;
  int totalsum = 0;

  int sum = 0;

  for (int i = 0; i < n; i++)
  {
    totalsum += arr[i];
  }
  for (int j = 0; j < n - k; j++)
  {
    sum += arr[j];
  }
  int min_sum = sum;
  for (int right = n - k; right < n; right++)
  {
    sum += arr[right] - arr[left];
    left++;
    min_sum = min(sum, min_sum);
  }
  int max_point = totalsum - min_sum;
  cout << max_point;
}
