#include <iostream>
using namespace std;

int main()
{
    int arr[] = {1, 1, 2, 2, 1};
    int k = 3;
    int n = 5;
    int count = 0;
    for (int st = 0; st < n; st++)
    {
        int countodd = 0;
        for (int end = st; end < n; end++)
        {
            if (arr[end] % 2 != 0)
            {
                countodd++;
            }
            if (countodd == k)
            {
                count++;
            }
        }
    }
    cout << count;
}
