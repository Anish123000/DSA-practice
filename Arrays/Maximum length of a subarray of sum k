#include <iostream>
using namespace std;
int main()
{
    int arr[] = {1, 2, 3, 4};
    int length = 0;
    int k = 3;
    int n = 4;
    for (int st = 0; st < n; st++)
    {
        int sum = 0;
        for (int end = st; end < n; end++)
        {
            sum += arr[end];
            if (sum == k)
            {
                length = max(length,end-st+1);
            }
        }
    }
    cout << length;
}
