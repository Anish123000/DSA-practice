#include <iostream>
#include <vector>
using namespace std;
int main()
{
    vector<int> a = {1, 1, 2, 2, 3, 4, 4, 5, 5};
    int st = 0, end = a.size() - 1;
    if (a.size() == 1)
    {
        cout << a[0];
    }
    while (st <= end)
    {
        int mid = st + (end - st) / 2;
        if (mid == 0 && a[0] != a[1])
        {
            cout << a[mid];
        }
        if (mid == a.size() - 1 && a.size() - 1 != a.size() - 2)
        {
            cout << a[mid];
        }
        if (a[mid - 1] != a[mid] && a[mid] != a[mid + 1])
        {
            cout << a[mid];
        }
        if (mid % 2 == 0)
        {
            if (a[mid - 1] == a[mid])
            {
                end = mid - 1;
            }
            else
            {
                st = mid + 1;
            }
        }

        else
        {
            if (a[mid - 1] == a[mid])
            {
                st = mid + 1;
            }
            else
            {
                end = mid - 1;
            }
        }
    }
    return -1;
}
