#include <iostream>
using namespace std;
int main()
{
    int arr[] = {7, 8, 3, 9, 0};
    int k = 2;
    int temp[k];
    for (int i = 0; i < k; i++)
    {
        temp[i] = arr[i];
    }
    for (int i = k; i < 5; i++)
    {
        arr[i - k] = arr[i];
    }
    for (int i = 0; i < k; i++)
    {
        arr[5 - k + i] = temp[i];
    }
    for (int i = 0; i < 5; i++)
    {
        cout << arr[i];
    }
}
