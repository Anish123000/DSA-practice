//optimise 
#include <iostream>
#include <unordered_map>
using namespace std;

int main()
{
    int arr[] = {1, 4, 3, 7, 6};
    int n = 5;
    int k = 7;

    unordered_map<int, int> mp;
    mp[0] = 1;

    int sum = 0, count = 0;

    for (int i = 0; i < n; i++)
    {
        sum += arr[i];

        if (mp.find(sum - k) != mp.end())
        {
            count += mp[sum - k];
        }

        mp[sum]++;
    }

    cout << count;
}
