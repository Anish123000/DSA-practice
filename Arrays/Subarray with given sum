#include <iostream>
using namespace std;
int main()
{
    int arr[] = {1, 4, 3, 7, 6};
    int n = 5;
    int target = 14;

    for (int st = 0; st < n; st++)
    {
        int sum = 0;
        for (int end =st ; end < n; end++)
        {
            sum = sum + arr[end];
            if (sum == target)
            {
                for (int i = st; i <= end; i++)
                {
                    cout << arr[i]<<" ";
                }
            }
        }
    }
}
