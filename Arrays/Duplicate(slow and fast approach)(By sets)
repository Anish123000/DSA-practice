#include <iostream>
#include <unordered_set>

using namespace std;
int main()
{
    unordered_set<int> s;
    int arr[5] = {1, 2, 2, 3, 4};
    int n = 5;
    for (int i = 0; i < n; i++)
    {
        if (s.find(arr[i]) != s.end())
        {
            cout << arr[i];
        }
        s.insert(arr[i]);
    }

    return -1;
}
