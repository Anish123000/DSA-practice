#include <iostream>
using namespace std;
int main()
{

    int arr[5] = {1, 2, 2, 3, 4};
    int n = 5;
    int slow = arr[0], fast = arr[0];
    do
    {
        slow = arr[slow];
        fast = arr[arr[fast]];

    } while (slow != fast);
    slow = arr[0];
    while (slow != fast)
    {
        slow = arr[slow];
        fast = arr[fast];
    }

    cout << slow;
}

