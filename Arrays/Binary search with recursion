#include <iostream>
using namespace std;
#include <vector>
int binarysearch(vector<int> arr, int tar1, int st, int end)
{
    if (st <= end)
    {
        int mid = st + (end - st) / 2;
        if (tar1 > arr[mid])
        {
            return binarysearch(arr, tar1, mid + 1, end);
        }
        else if (tar1 < arr[mid])
        {
            return binarysearch(arr, tar1, st, mid - 1);
        }
        else
        {
            return mid;
        }
    }
    return -1;
}

int main()
{
    vector<int> arr1 = {2, 5, 7, 8, 9};
    int target = 8;
    cout << binarysearch(arr1, target, 0, arr1.size() - 1) << endl;
}
