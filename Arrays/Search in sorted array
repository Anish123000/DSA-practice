#include <iostream>
#include <vector>
using namespace std;
int main()
{

    vector<int> a = {4, 5, 6, 7, 0, 1, 2};
    int tar = 4;
    int st = 0, end = a.size() - 1;
    while (st <= end)
    {
        int mid = st + (end - st) / 2;
        if (a[mid] == tar)
        {
            cout << mid;
            return 0;
        }
        if (a[st] <= a[mid])
        {
            if (a[st] <= tar && tar <= a[mid])
            {
                end = mid - 1;
            }
            else
            {
                st = mid + 1;
            }
        }
        else
        {
            if (a[mid] <= tar && tar <= a[end])
            {
                st = mid + 1;
            }
            else
            {
                end = mid - 1;
            }
        }
    }
    cout << -1;
}
