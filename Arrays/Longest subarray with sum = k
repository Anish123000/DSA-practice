#include <iostream>
using namespace std;
int main()
{
    int arr[] = {1, 2, 3, 1, 1, 1};
    int n = 6;
    int length;
    int maxlen = 0;
    ;
    int k = 3;
    for (int st = 0; st < n; st++)
    {
        int sum = 0;
        for (int end = st; end < n; end++)
        {
            sum += arr[end];
            if (sum == k)
            {
                length = end - st + 1;
                maxlen = max(maxlen, length);
            }
        }
    }
    cout << maxlen;
}
