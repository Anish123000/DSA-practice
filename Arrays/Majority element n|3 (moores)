
#include <iostream>
#include <vector>
using namespace std;
int main()
{
    vector<int> nums = {0, 1, 1, 2, 2, 2};
    int count1 = 0;
    int count2 = 0;
    int freq1 = 0;
    int freq2 = 0;
 
    for (int i = 0; i < nums.size(); i++)
    {

        if (nums[i] == count1)
        {
            freq1++;
        }
        else if (nums[i] == count2)
        {
            freq2++;
        }
        else if (freq1 == 0)
        {
            count1 = nums[i];
            freq1 = 1;
        }
        else if (freq2 == 0)
        {
            count2 = nums[i];
            freq2 = 1;
        }
        else
        {
            freq1--;
            freq2--;
        }
    }
    freq1 = 0;
    freq2 = 0;

    for (int i = 0; i < nums.size(); i++)
    {
        if (nums[i] == count1)
            freq1++;
        else if (nums[i] == count2)
            freq2++;
    }

    if (freq1 > nums.size() / 3)
        cout << count1 << " ";
    if (freq2 > nums.size() / 3)
        cout << count2;

    return 0;
}
