#include <iostream>
using namespace std;
int main()
{
    int arr[] = {2, 4, 3, 7, 8, 9};
    int secondlargest = arr[0];
    int largest = arr[0];
    for (int i = 1; i < 6; i++)
    {
        if (arr[i] > largest)
        {
            secondlargest = largest;
            largest = arr[i];
        }
        else if (arr[i] > secondlargest && arr[i] < largest)
        {
            secondlargest = arr[i];
        }
    }
    cout << secondlargest;
}
