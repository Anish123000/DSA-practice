 
#include <iostream>
#include <vector>
using namespace std;
int main()
{
    vector<int> nums = {2, 3, 4, 5};

    for (int i = 0; i < nums.size(); i++)
    {
        int product = 1;
        for (int j = 0; j < nums.size(); j++)
        {
            if (i != j)
            {
                product *= nums[j];
            }
        }
        cout << product << endl;
    }
}
