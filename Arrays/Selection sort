Time Complexity: O(n^2)
Space Complexity: O(1)
#include <iostream>
#include <vector>
using namespace std;
void selectionsort(int arr[], int n)
{
    for (int i = 0; i < n - 1; i++)
    {
        int smallestindex = i;
        for (int j = i+1; j < n  ; j++)
        {

            if (arr[j] < arr[smallestindex])
            {
                 smallestindex = j;
            }
        }
        swap(arr[i],arr[smallestindex]);
    }
}
void print(int arr[], int n)
{
    for (int i = 0; i < n; i++)
    {
        cout << arr[i] << " ";
    }
    cout << endl;
}

int main()
{
    int arr[] = {1, 5, 3, 8, 7};
    int n = 5;
    selectionsort(arr, n);
    print(arr, n);
    return 0;
}
