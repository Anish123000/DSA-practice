#include <iostream>
#include <unordered_set>
#include <vector>
using namespace std;
int main()
{
    vector<vector<int>> vec = {{9, 1, 7}, {8, 9, 2}, {3, 4, 6}};
    unordered_set<int> s;
    int n = vec.size();
    int a, b;
    vector<int> ans;
    int expsum = 0;
    int actsum = 0;
    for (int i = 0; i < n; i++)
    {
        for (int j = 0; j < n; j++)
        {
            actsum += vec[i][j];
            if (s.find(vec[i][j]) != s.end())
            {
                a = vec[i][j];
                ans.push_back(a);
            }
            s.insert(vec[i][j]);
        }
    }
    expsum = (n * n) * (n * n + 1) / 2;
    b = expsum + a - actsum;
    ans.push_back(b);

    cout << "duplicate value is " << ans[0] << endl;
    cout << " missing value is " << ans[1];
}
