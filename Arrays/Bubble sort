//Time Complexity: O(n^2)
//Space Complexity: O(1)
#include <iostream>
#include <vector>
using namespace std;
void bubblesort(int arr[], int n)
{
    for (int i = 0; i < n - 1; i++)
    {
        for (int j = 0; j < n - i - 1; j++)
        {

            if (arr[j] > arr[j + 1])
            {
                swap(arr[j], arr[j + 1]);
            }
        }
    }
}
void print(int arr[], int n)
{
    for (int i = 0; i < n; i++)
    {
        cout << arr[i] << " ";
    }
    cout << endl;
}

int main()
{
    int arr[] = {1, 5, 3, 8, 7};
    int n = 5;
    bubblesort(arr, n);
    print(arr, n);
    return 0;
}
