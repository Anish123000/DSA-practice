
#include <iostream>
#include <climits>
#include <unordered_map>
using namespace std;

int shortestsubarray(int arr1[], int n, int k)
{

    unordered_map<int, int> prefixsum;
    int currsum = 0;
    int minlen = INT_MAX;
    for (int i = 0; i < n; i++)
    {
        currsum += arr1[i];
        if (currsum == k)
        {
            minlen = min(minlen, i + 1);
        }
        if (prefixsum.find(currsum - k) != prefixsum.end())
        {
            int len = i - prefixsum[currsum - k];
            minlen = min(len, minlen);
        }
        if (prefixsum.find(currsum) == prefixsum.end())
        {
            prefixsum[currsum] = i;
        }
    }
    if (minlen == INT_MAX)
        return 0;

    return minlen;
}

int main()
{
    int arr[] = {1, 2, 1, 1, 1};
    int n = 6;

    int k = 3;
    cout << shortestsubarray(arr, n, k);
}
