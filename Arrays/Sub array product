#include <iostream>
using namespace std;
int main()
{
    int arr[] = {2, 3, -4, 7, -4, 8};
    int n = 6;
    int maxpod = arr[0];
    int minpod = arr[0];
    int ans = arr[0];
    for (int i = 1; i < n; i++)
    {
        if (arr[i] < 0)
        {
            swap(maxpod, minpod);
        }
        maxpod = max(arr[i], maxpod * arr[i]);
        minpod = min(arr[i], minpod * arr[i]);
        ans = max(ans, maxpod);
    }
    cout << ans;
}
