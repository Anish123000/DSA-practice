#include <iostream>
using namespace std;
int main()
{
    int A[] = {1, 2, 3, 0, 0, 0};
    int n = 3;
    int B[] = {4, 5, 6};
    int m = 3;
    int index = n + m - 1;
    int i = n - 1;
    int j = m - 1;
    while (i >= 0 && j >= 0)
    {
        if (A[i] >= B[j])
        {
            A[index] = A[i];
            i--;
            index--;
        }
        else
        {
            A[index] = B[j];
            index--;
            j--;
        }
    }

    while (j >= 0)
    {
        A[index] = B[j];
        index--;
        j--;
    }
    for (int k = 0; k < 6; k++)
    {
        cout << A[k];
    }
}
