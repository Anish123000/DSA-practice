brute force
#include <iostream>
#include <vector>
    using namespace std;
int main()
{

    vector<int> nums = {1, 2, 4, 4, 4, 4, 6, 6, 7};
    int n = nums.size();
    for (int val : nums)
    {

        int freq = 0;
        for (int el : nums)
        {
            if (el == val)
            {
                freq++;
            }
        }
        if (freq > n / 2)
        {
            cout << val << " ";
            break;
        }
    }
}
